# ============================================================
# FinAI Trader — Environment Configuration
# Copy this file to .env and fill in your real values
# ============================================================

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=finai
POSTGRES_PASSWORD=finai
POSTGRES_DB=finai_trader

# ── JWT Authentication ─────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-secure-random-string

# ── Exchange API Keys ──────────────────────────────────────
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# ── Social Media APIs ──────────────────────────────────────
# Twitter / X API Bearer Token (for live tweet fetching)
TWITTER_BEARER_TOKEN=

# Reddit API (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Google Cloud / BigQuery ────────────────────────────────
GCP_PROJECT_ID=
# Path to service account JSON inside container
GOOGLE_APPLICATION_CREDENTIALS=/gcp/service-account.json

# ── Frontend (Next.js public vars) ─────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000/api
NEXT_PUBLIC_WS_BASE=ws://localhost:8000
